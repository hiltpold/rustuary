{
  "name": "rustuary",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/rust:1": {
      "version": "1.78.0",
      "profile": "minimal"
    },
    "ghcr.io/devcontainers/features/go:1": {
      "version": "1.23.4"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22.12.0"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12.4"
    }
  },
  "postCreateCommand": "corepack enable && corepack prepare pnpm@9.15.0 --activate && pipx install uv || true && cargo --version && go version && node --version && python --version",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb",
        "golang.go",
        "svelte.svelte-vscode",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-python.python",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml"
      ]
    }
  }
}
